# ============================================================================
# Vault Enterprise DR on AWS - Example Configuration
# ============================================================================
# Copy this file to terraform.tfvars and fill in your values
# ============================================================================

# ============================================================================
# General Configuration
# ============================================================================

environment  = "dev"
owner        = "dev-team"
project_name = "vault-integration-lab"

# ============================================================================
# Region Configuration
# ============================================================================

primary_region = "us-east-1"
dr_region      = "us-east-2"

# ============================================================================
# Network Configuration
# ============================================================================

primary_vpc_cidr = "10.0.0.0/16"
dr_vpc_cidr      = "10.1.0.0/16"

# Enable VPC peering for DR replication
enable_vpc_peering = true

# CIDR blocks allowed to access Vault API
# Adjust based on your network requirements
allowed_inbound_cidrs = [
  "10.0.0.0/8",    # Internal networks
  # "203.0.113.0/24" # Example: Your office network
]

# CIDR blocks allowed for SSH access (empty = no SSH)
# For production, use bastion host or VPN
allowed_ssh_cidrs = []

# ============================================================================
# Vault Configuration
# ============================================================================

vault_version = "1.21.1+ent"

# REQUIRED: Your Vault Enterprise license
# Get from: https://releases.hashicorp.com/vault/
vault_license = "XXXXXXXXXXXXXXXXXXXXXXX"

vault_cluster_name_primary = "vault-primary"
vault_cluster_name_dr      = "vault-dr"

# Number of Vault nodes per cluster (must be odd: 3, 5, 7)
vault_node_count = 3

# ============================================================================
# EC2 Configuration
# ============================================================================

# Instance type for Vault nodes
# t3.xlarge = 4 vCPU, 16 GB RAM (recommended minimum)
# t3.2xlarge = 8 vCPU, 32 GB RAM (for high load)
vault_instance_type = "t3.xlarge"

# Storage configuration
vault_root_volume_size = 50   # GB
vault_data_volume_size = 100  # GB (Raft storage)
vault_data_volume_type = "gp3"
vault_data_volume_iops = 3000
vault_data_volume_throughput = 125 # MB/s

# AMI IDs (leave empty for auto-lookup of Ubuntu 22.04 LTS)
ami_id_primary = ""
ami_id_dr      = ""

# SSH key name (leave empty to auto-generate)
# If you have an existing EC2 key pair, specify it here
ssh_key_name = ""

# ============================================================================
# Load Balancer Configuration
# ============================================================================

lb_internal = false       # true = internal LB, false = internet-facing

enable_cross_zone_load_balancing = true

# ============================================================================
# Auto-Unseal Configuration (AWS KMS)
# ============================================================================

enable_auto_unseal      = true
kms_key_deletion_window = 30  # days
enable_kms_key_rotation = true

# ============================================================================
# Monitoring & Logging
# ============================================================================

enable_cloudwatch_logs        = true
cloudwatch_log_retention_days = 30
enable_detailed_monitoring    = true
enable_audit_logging          = true

# ============================================================================
# Backup Configuration
# ============================================================================

enable_ebs_snapshots    = true
snapshot_retention_days = 7

# ============================================================================
# Security Configuration
# ============================================================================

enable_ebs_encryption = true
enable_imdsv2         = true  # Require IMDSv2 for metadata service

# ============================================================================
# DR Replication Configuration
# ============================================================================

enable_dr_replication = true

# ============================================================================
# Feature Flags
# ============================================================================

enable_termination_protection = true
enable_deletion_protection_lb = true
create_bastion_host           = false

# ============================================================================
# Additional Tags
# ============================================================================

additional_tags = {
  CostCenter  = "engineering"
  Compliance  = "pci-dss"
  Backup      = "daily"
  Department  = "platform"
}

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. VAULT LICENSE: You MUST provide a valid Vault Enterprise license
#    Get it from: https://portal.hashicorp.com
# 
# 2. NETWORK ACCESS: By default, Vault is deployed in private subnets
#    You'll need a bastion host, VPN, or VPC peering to access it
# 
# 3. SSH ACCESS: For production, leave allowed_ssh_cidrs empty and use
#    AWS Systems Manager Session Manager for secure access
# 
# 4. COST: Estimated monthly cost is ~$802 USD for both clusters
#    - Primary: ~$401/month
#    - DR: ~$401/month
# 
# 5. REGIONS: Primary and DR must be in different regions for true DR
#    Default: us-east-1 (primary) and us-east-2 (DR)
# 
# 6. INSTANCE SIZING: t3.xlarge is minimum recommended
#    For production with high load, consider t3.2xlarge or larger
# 
# 7. STORAGE: 100GB data volume is for Raft storage
#    Adjust based on your expected data volume
# 
# 8. AUTO-UNSEAL: Requires AWS KMS permissions
#    IAM role is automatically created with required permissions
# 
# ============================================================================
